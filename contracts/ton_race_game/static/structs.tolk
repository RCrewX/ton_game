import "constants"

type Y_TYPE = uint64
type X_TYPE = int64
type HP_TYPE = Y_TYPE

const Y_TYPE_BITS: int = 64
const X_TYPE_BITS: int = 64
const HP_TYPE_BITS: int = 64

