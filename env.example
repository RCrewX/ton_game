# =============================================================================
# .env.example — UNIFIED template for ton_game + ultimate_amusement_park (UAT).
# Copy to .env and fill in, OR generate with Brain/Files/scripts/sync-env.sh.
# PLACEHOLDERS ONLY — never put real keys here (this file is committed to git).
# Provider definitions live in: node_modules/ton-provider-system/rpc.json
# =============================================================================

# ---------- Network (NETWORK=uap, TON_NETWORK=ton_game; keep in lockstep) ----
NETWORK=testnet
TON_NETWORK=testnet

# ---------- uap: server / origins -------------------------------------------
PORT=3000
PUBLIC_ORIGIN=https://testnet.example.tld
CORS_EXTRA_ORIGINS=
LOG_LEVEL=info

# ---------- uap: database ----------------------------------------------------
DATABASE_URL=postgresql://uap:CHANGE_ME@db:5432/uap_testnet

# ---------- uap: sessions / admin -------------------------------------------
# SESSION_SECRET >=32 chars. Generate: openssl rand -hex 32 (sync-env.sh auto-fills if blank).
SESSION_SECRET=
ADMIN_WALLETS=

# ---------- uap: scheduler RPM ceilings (required by uap; no code defaults) --
RPM_INDEXER_SCAN=300
RPM_USER_API_READ=600
RPM_PLAY_ACTION_VERIFY=120
RPM_ADMIN_ACTION=60
RPM_WAIT_MAX_MS=5000

# ---------- uap: TonAPI streaming/webhook -----------------------------------
# TONAPI_KEY required for uap (separate vendor from the RPC providers).
TONAPI_KEY=
# TONAPI_WEBHOOK_SECRET >=16 chars. Generate: openssl rand -hex 32 (sync-env.sh auto-fills if blank).
TONAPI_WEBHOOK_SECRET=
TONAPI_SSE_ENDPOINT=
TONAPI_RPM_CAP=600
TONAPI_BURST_CAP=30

# ---------- ton_game: deploy wallet -----------------------------------------
# PRIVATE_KEY 128 hex chars (pnpm generate-key). OR set MNEMONIC (24 words) instead.
PRIVATE_KEY=
MNEMONIC=
OWNER_PUBLIC_KEY=
WALLET_VERSION=v4r2

# ---------- Provider RPC keys (shared; all optional; Orbs needs none) --------
# Chainstack testnet 25 RPS · TON Center 10 RPS w/ key (https://t.me/tonapibot) · OnFinality 4 ·
# Tatum 3 (x-api-key) · QuickNode/GetBlock = mainnet. Keyless => TON Center 1 RPS (flaky).
TONCENTER_API_KEY=
CHAINSTACK_KEY_TESTNET=
CHAINSTACK_KEY_MAINNET=
ONFINALITY_KEY_TESTNET=
ONFINALITY_KEY_MAINNET=
TATUM_API_KEY_TESTNET=
TATUM_API_KEY_MAINNET=
QUICKNODE_KEY_MAINNET=
GETBLOCK_KEY_MAINNET=

# ---------- ton_game: legacy Chainstack endpoint URLs (sync-env.sh derives) --
CHAINSTACK_API_V2=
CHAINSTACK_API_V3=
CHAINSTACK_API_MAINNET_V2=
CHAINSTACK_API_MAINNET_V3=
