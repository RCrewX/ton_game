# =============================================================================
# TON Game - Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are optional - the system will use available providers.
#
# Provider definitions are in: node_modules/ton-provider-system/rpc.json
# This file only contains API keys and secrets.

# =============================================================================
# WALLET CONFIGURATION
# =============================================================================

# Private key for deployments (128 hex characters)
# Generate with: pnpm generate-key
PRIVATE_KEY=

# Mnemonic phrase (alternative to PRIVATE_KEY, 24 words)
# MNEMONIC=word1 word2 word3 ...

# =============================================================================
# RPC PROVIDERS - API KEYS
# =============================================================================
# Configure as many providers as you want for redundancy.
# The system will automatically select the best available provider.

# -----------------------------------------------------------------------------
# TON Center (https://toncenter.com)
# RPS: 10 with API key, 1 without
# Get free API key at: https://t.me/tonapibot
# -----------------------------------------------------------------------------
TONCENTER_API_KEY=4d5dbec8cc65f846aebac36aaf38fca7b6e86767d97ef501ad8e0b7fb218541a

# -----------------------------------------------------------------------------
# Chainstack (https://chainstack.com)
# RPS: 25 (free plan)
# TESTNET only for now (mainnet requires paid plan)
# Extract key from your endpoint URL:
#   URL: https://ton-testnet.core.chainstack.com/e660b915affe67c176f1479b3ec7c7d6/api/v2
#   Key: e660b915affe67c176f1479b3ec7c7d6
# -----------------------------------------------------------------------------
CHAINSTACK_KEY_TESTNET=e660b915affe67c176f1479b3ec7c7d6
# CHAINSTACK_KEY_MAINNET=your-mainnet-key-here

# Legacy format (backward compatibility with existing scripts)
CHAINSTACK_API_V2=https://ton-testnet.core.chainstack.com/e660b915affe67c176f1479b3ec7c7d6/api/v2
CHAINSTACK_API_V3=https://ton-testnet.core.chainstack.com/e660b915affe67c176f1479b3ec7c7d6/api/v3
# CHAINSTACK_API_MAINNET_V2=https://ton-mainnet.core.chainstack.com/your-key/api/v2
# CHAINSTACK_API_MAINNET_V3=https://ton-mainnet.core.chainstack.com/your-key/api/v3

# -----------------------------------------------------------------------------
# GetBlock (https://getblock.io)
# RPS: 20
# MAINNET only
# Get access token at: https://account.getblock.io/
# -----------------------------------------------------------------------------
GETBLOCK_KEY_MAINNET=4e0b2a2ae1824e9fb32b9008004c57af

# -----------------------------------------------------------------------------
# OnFinality (https://onfinality.io)
# RPS: 4 (free tier)
# TESTNET only for now
# Dashboard: https://app.onfinality.io/
# -----------------------------------------------------------------------------
ONFINALITY_KEY_TESTNET=c2720443-bda9-478c-a021-a71c4b04004a
# Additional OnFinality credentials (not used by ton-provider-system, for reference)
# ONFINALITY_ACCESS_KEY=iHk1urXcGAwub6JjxtZxZxsR9yfcU8VV
# ONFINALITY_SECRET_KEY=SvFhsDuUUgxe6wDdLFee8I5qzNFQ0mfFG1zMUmL6

# -----------------------------------------------------------------------------
# QuickNode (https://quicknode.com)
# RPS: 15 (free plan)
# MAINNET only
# Dashboard: https://dashboard.quicknode.com/
# Extract subdomain from your endpoint URL:
#   URL: https://prettiest-white-wind.ton-mainnet.quiknode.pro/e03d6f3a9bb0355f6135e948e2bc5458e20d76a0/
#   Key: prettiest-white-wind
# -----------------------------------------------------------------------------
QUICKNODE_KEY_MAINNET=prettiest-white-wind

# -----------------------------------------------------------------------------
# Tatum (https://tatum.io)
# RPS: 3 (free plan)
# Dashboard: https://dashboard.tatum.io/
# Uses x-api-key header for authentication
# -----------------------------------------------------------------------------
TATUM_API_KEY_TESTNET=t-696f4553ad6869a6010a0e39-063ee849578b4d44bc8e430a
TATUM_API_KEY_MAINNET=t-696f4553ad6869a6010a0e39-be4eda89620140239e89164a
# Legacy single key (if same key works for both networks)
TATUM_API_KEY=t-696f4553ad6869a6010a0e39-063ee849578b4d44bc8e430a

# =============================================================================
# PROVIDER SUMMARY
# =============================================================================
#
# | Provider   | Network  | RPS | Priority | Notes                          |
# |------------|----------|-----|----------|--------------------------------|
# | Chainstack | testnet  | 25  | 1        | Best for testnet development   |
# | Chainstack | mainnet  | 25  | 1        | Requires paid plan             |
# | TON Center | both     | 10  | 50       | Official, reliable with key    |
# | OnFinality | testnet  | 4   | 5        | Good fallback for testnet      |
# | QuickNode  | mainnet  | 15  | 2        | Fast mainnet option            |
# | GetBlock   | mainnet  | 20  | 3        | Good mainnet option            |
# | Tatum      | both     | 3   | 8        | Lower RPS but reliable         |
# | Orbs       | both     | 10  | 10       | Free, no key needed, dynamic   |
#
# =============================================================================

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Jetton metadata URI for deployment
# JETTON_CONTENT_URI=https://your-domain.com/jetton-metadata.json

# Custom network (testnet or mainnet)
# NETWORK=testnet
